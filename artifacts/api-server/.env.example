# Set these in Vercel. Never commit a real value to this file.
DATABASE_URL=postgresql://...
JWT_SECRET=replace-with-a-long-random-secret
# Optional one-time pitch seed trigger for POST /api/admin/enrich-demo (Vercel only).
ENRICH_DEMO_SECRET=
FRONTEND_URL=https://cohort-1-squad-indus-sweet-tooth.vercel.app

# Optional Clerk (Google SSO). When unset, native email/password auth is used.
# AUTH_MODE=clerk          — hybrid: Clerk + native JWT both work (recommended)
# AUTH_MODE=legacy         — native only, ignore Clerk on dashboard routes
# AUTH_MODE=clerk-only     — Clerk required; native register/login disabled
AUTH_MODE=clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Enables real AI replies and OpenAI embeddings.
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Free server-side receipt OCR. Only exact hosts listed here may be fetched.
RECEIPT_IMAGE_HOSTS=your-private-receipt-storage.example
# Self-host eng.traineddata.gz for deterministic production OCR.
TESSERACT_LANG_PATH=https://your-static-assets.example/tesseract

# Optional n8n automation bridge. Create a production Webhook trigger in n8n
# and put its URL here. The secret is sent in X-Indus-Webhook-Secret.
N8N_WEBHOOK_URL=https://your-n8n.example/webhook/indus-events
N8N_WEBHOOK_SECRET=replace-with-a-long-random-secret

# WhatsApp Business Cloud API (only after Meta setup is complete).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_APP_ID=
META_CONFIG_ID=
META_OAUTH_REDIRECT_URI=https://your-api.example/api/meta/callback
TOKEN_ENCRYPTION_KEY=
