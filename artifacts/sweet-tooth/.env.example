# Frontend (Vite) — set in Vercel Project Settings for Production + Preview.
# Never commit real secrets. Rebuild after changing VITE_* vars.

VITE_API_URL=https://cohort-1-squad-indus-api-server-z3b.vercel.app

# Optional. When unset, native email/password login is used and Clerk SSO is hidden.
# Use pk_live_… on the production domain (pk_test_ only works on Clerk allowed hosts).
VITE_CLERK_PUBLISHABLE_KEY=

# Meta Embedded Signup (WhatsApp + Instagram connect in Agent Hub)
VITE_META_APP_ID=
VITE_META_CONFIG_ID=
# Optional separate Instagram config; falls back to VITE_META_CONFIG_ID
VITE_META_IG_CONFIG_ID=
